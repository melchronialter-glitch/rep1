# =============================================================================
# CryptoBot environment configuration
# Copy to .env and fill in. Anything left blank is treated as not configured.
# =============================================================================

# ---- Postgres -------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=cryptobot
POSTGRES_PASSWORD=cryptobot
POSTGRES_DB=cryptobot

# ---- Redis ----------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ---- Anthropic (required for any analysis) -------------------------------
ANTHROPIC_API_KEY=

# ---- Telegram outbound (required for Phase A demo) -----------------------
# Create a bot via @BotFather, then create 4 channels/groups and add the bot
# as admin. Use @userinfobot to find chat IDs (negative numbers for channels).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_STRICT=
TELEGRAM_CHAT_MEDIUM=
TELEGRAM_CHAT_FIREHOSE=
TELEGRAM_CHAT_MACRO=
# Your personal DM chat ID for on-demand commands and personal alerts
TELEGRAM_CHAT_DM=

# ---- Logging --------------------------------------------------------------
LOG_LEVEL=INFO
LOG_JSON=false

# =============================================================================
# Below this line are NOT used in Phase A. Filled in during later phases.
# =============================================================================

# ---- Phase B: news + market data -----------------------------------------
CRYPTOPANIC_API_KEY=
NEWS_API_KEY=

# ---- Phase C: chain watchers ---------------------------------------------
HELIUS_API_KEY=
ALCHEMY_API_KEY=
QUICKNODE_BSC_URL=

# ---- Phase E: social listeners -------------------------------------------
TELEGRAM_USER_API_ID=
TELEGRAM_USER_API_HASH=
TELEGRAM_USER_PHONE=
DISCORD_USER_TOKEN=
APIFY_API_TOKEN=
TWITTERAPI_IO_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=CryptoBot/0.1

# ---- Phase G: derivatives + macro ----------------------------------------
COINGLASS_API_KEY=

# ---- Email (optional, used from Phase B for digests) --------------------
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=
